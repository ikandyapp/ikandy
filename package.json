{
  "name": "IKANDY",
  "version": "1.0.1",
  "description": "IKANDY — Music visualizer (Butterchurn / MilkDrop)",
  "main": "main.js",
  "author": "Felix Bag of Tricks",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron . --log-level=3",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ikandy.ikandy",
    "productName": "IKANDY",
    "executableName": "IKANDY",
    "copyright": "Felix Bag of Tricks",
    "files": [
      "main.js",
      "preload.js",
      "IKANDY.html",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName} Setup.${ext}"
    },
    "linux": {
      "icon": "icon.png",
      "target": [
        "AppImage"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "ikandyapp",
      "repo": "ikandy"
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  }
}
